# Optionnel : synchro cloud Supabase (voir README.md)
# Si ces variables sont absentes, l'app tourne en mode local (localStorage)
# et la config peut aussi se faire directement dans l'app (Réglages).
VITE_SUPABASE_URL=https://xxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOi...

# Optionnel : analyse IA GRATUITE des lieux « Découvrir » (Google Gemini).
# À définir côté serveur (variable d'environnement Vercel, PAS de préfixe VITE_ :
# la clé ne doit jamais partir dans le navigateur). Sans elle, la découverte
# fonctionne quand même (danger calculé + histoire Wikipédia).
# Clé gratuite (sans carte) : https://aistudio.google.com → « Get API key ».
# GEMINI_API_KEY=AIza...
# GEMINI_MODEL=gemini-2.0-flash   # (optionnel) modèle Gemini à utiliser
